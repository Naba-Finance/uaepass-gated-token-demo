# Address of the deployed NabaUAEGatedToken on Polygon mainnet.
VITE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: override the RPC used for reads (otherwise Polygon's public RPC).
VITE_RPC_URL=

# WalletConnect project id (free, from https://cloud.reown.com).
# When set, a WalletConnect (QR / mobile) connector is added alongside injected.
VITE_WC_PROJECT_ID=
